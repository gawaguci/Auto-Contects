# ----------------------------------------------------------------------------
# Auto-Contects environment template
# Copy this file to .env and fill only the providers you actually use.
# ----------------------------------------------------------------------------

# Claude API (optional)
# 0 = local AI mode only, 1 = enable Claude API calls
USE_CLAUDE_API=0
ANTHROPIC_API_KEY=

# Image generation / image source (optional)
# At least one of these is recommended for external images.
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
PEXELS_API_KEY=
PIXABAY_API_KEY=

# TTS providers (optional)
ELEVENLABS_API_KEY=
TYPECAST_API_KEY=
TYPECAST_VOICE_ID=

# Remotion browser override (optional)
REMOTION_BROWSER_EXECUTABLE=

# FFmpeg binary paths (optional, Windows fallback)
# Example when ffmpeg is installed at C:\ffmpeg\
FFMPEG_PATH=C:\ffmpeg\ffmpeg.exe
FFMPEG_BIN=
FFPROBE_BIN=C:\ffmpeg\ffprobe.exe
